# ─── App ───────────────────────────────────────────────────
APP_ENV=development
APP_NAME="Personal Tracking AI Assistant"
APP_DEBUG=true
LOG_LEVEL=INFO

# ─── Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# ─── Security ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change_me_to_a_long_random_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ptaa:ptaa_dev_password@localhost:5432/ptaa
DATABASE_URL_SYNC=postgresql+psycopg2://ptaa:ptaa_dev_password@localhost:5432/ptaa

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AI ────────────────────────────────────────────────────
# Supported: openai, anthropic, mock
AI_PROVIDER=mock
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Rate limiting ─────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
